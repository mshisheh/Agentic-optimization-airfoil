FoamFile
{
    version     2.0;
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}

internalField   uniform (Ux Uy 0);

boundaryField
{
    farfield
    {
        type freestream;
        freestreamValue uniform (Ux Uy 0);
    }
}
